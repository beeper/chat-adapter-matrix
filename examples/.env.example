# Required
MATRIX_BASE_URL=https://matrix.beeper.com

# Option A: access token auth
MATRIX_ACCESS_TOKEN=your_access_token
MATRIX_USER_ID=@bot:beeper.com

# Option B: password auth
# MATRIX_USERNAME=bot
# MATRIX_PASSWORD=secret
# MATRIX_USER_ID=@bot:beeper.com

# Optional
MATRIX_DEVICE_ID=
MATRIX_RECOVERY_KEY=
MATRIX_E2EE_ENABLED=
MATRIX_E2EE_USE_INDEXEDDB=true
MATRIX_E2EE_DB_PREFIX=beeper-chat-adapter-matrix
MATRIX_E2EE_STORAGE_PASSWORD=
MATRIX_E2EE_STORAGE_KEY_BASE64=
MATRIX_SESSION_ENABLED=true
MATRIX_SESSION_KEY=
MATRIX_SESSION_TTL_MS=
BOT_USER_NAME=beeper-bot
REDIS_URL=redis://localhost:6379

# Both required
E2E_BASE_URL=https://matrix.example.com

# Bot account (used by the adapter)
E2E_BOT_ACCESS_TOKEN=...
E2E_BOT_USER_ID=@bot:example.com
# E2E_BOT_RECOVERY_KEY=EsTc...

# Sender account (second adapter instance)
E2E_SENDER_ACCESS_TOKEN=...
E2E_SENDER_USER_ID=@sender:example.com
# E2E_SENDER_RECOVERY_KEY=EsTc...

# Optional: use pre-existing room instead of creating one
# E2E_ROOM_ID=!abc:example.com

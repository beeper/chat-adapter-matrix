{
  "name": "@beeper/chat-adapter-matrix",
  "version": "0.1.0",
  "description": "Matrix adapter for chat",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "chat": "^4.13.4",
    "matrix-js-sdk": "^41.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beeper/chat-adapter-matrix.git"
  },
  "homepage": "https://github.com/beeper/chat-adapter-matrix#readme",
  "bugs": {
    "url": "https://github.com/beeper/chat-adapter-matrix/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "chat",
    "matrix",
    "bot",
    "adapter"
  ],
  "license": "MIT"
}
